{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cortex",
  "version": "0.1.0",
  "identifier": "com.cortexagentic.desktop",
  "build": {
    "frontendDist": "../../native/dist",
    "devUrl": "http://localhost:4173"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://cortex-agentic-production.up.railway.app https://*.clerk.accounts.dev; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../native/public/icons/icon-512x512.png"],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}
