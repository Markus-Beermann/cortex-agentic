{
  "name": "george-orchestrator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "Reusable multi-agent orchestration core for private project automation.",
  "scripts": {
    "bootstrap": "tsx src/cli/bootstrap.ts",
    "registry:list": "tsx src/cli/registry-list.ts",
    "registry:inspect": "tsx src/cli/registry-inspect.ts",
    "run:list": "tsx src/cli/run-list.ts",
    "run:inspect": "tsx src/cli/run-inspect.ts",
    "events:show": "tsx src/cli/events-show.ts",
    "dry-run": "tsx src/cli/dry-run.ts",
    "approvals:list": "tsx src/cli/list-approvals.ts",
    "approve": "tsx src/cli/approve.ts",
    "reject": "tsx src/cli/reject.ts",
    "resume": "tsx src/cli/resume-run.ts",
    "poll": "tsx src/cli/poll.ts",
    "hermes:poll-github": "tsx src/cli/hermes-poll-github.ts",
    "hermes:ingest-linkedin": "tsx src/cli/hermes-ingest-linkedin.ts",
    "hermes:nightly": "tsx src/cli/hermes-nightly.ts",
    "build:native": "npm run build --workspace=apps/native",
    "build:mobile": "npm run build --workspace=apps/native && cd apps/mobile && npx cap sync android",
    "build:desktop": "npm run build --workspace=apps/native && npm run build --workspace=apps/desktop",
    "build": "tsc -p tsconfig.json",
    "server": "tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@clerk/express": "^1.7.10",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
